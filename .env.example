# Diretório raiz onde ficam as pastas dos veículos.
# Estrutura esperada: veiculo/camera/AAAA-MM-DD/arquivo
IMAGE_DASHBOARD_ROOT=/home/publico/imagens

# Identificador da garagem local gravado no banco.
# Exemplos: G1, G2, TIJUCA_G1.
IMAGE_DASHBOARD_GARAGE=G1

# Banco usado pela aplicacao: sqlite ou postgres.
IMAGE_DASHBOARD_DB_ENGINE=sqlite

# Caminho do banco SQLite usado pela aplicação.
# Em produção, prefira um caminho fora do repositório.
IMAGE_DASHBOARD_DB=./db/dashboard_imagens.db

# DSN do PostgreSQL quando IMAGE_DASHBOARD_DB_ENGINE=postgres.
# Exemplo: postgresql://usuario:senha@127.0.0.1:5432/dashboard_imagens
IMAGE_DASHBOARD_POSTGRES_DSN=

# Tamanho do lote usado pelo script migrate_sqlite_to_postgres.py.
IMAGE_DASHBOARD_MIGRATION_BATCH_SIZE=5000

# Arquivo JSON onde a pagina /config salva ajustes feitos pela interface.
IMAGE_DASHBOARD_CONFIG_FILE=./config/dashboard_config.json

# Endereço e porta onde o servidor HTTP vai escutar.
# Use 0.0.0.0 para aceitar acesso de outras máquinas da rede.
IMAGE_DASHBOARD_HOST=0.0.0.0
IMAGE_DASHBOARD_PORT=8081

# Inicia uma indexação incremental automaticamente ao subir a aplicação.
# Use 0 para desativar.
IMAGE_DASHBOARD_AUTO_SCAN=1

# Intervalo, em segundos, entre indexações incrementais automáticas.
# 300 segundos = 5 minutos. Use 0 para desativar o agendador.
IMAGE_DASHBOARD_SCAN_INTERVAL_SECONDS=300

# Intervalo, em segundos, para tentar preencher a duração dos vídeos.
# A fila só roda quando não há indexação em andamento. Use 0 para desativar.
IMAGE_DASHBOARD_DURATION_INTERVAL_SECONDS=300

# Garagens remotas consultadas por esta instância.
# Formato: NOME:http://host:porta;NOME2:http://host2:porta
# Exemplo: G2:http://10.90.0.22:8081
IMAGE_DASHBOARD_REMOTE_GARAGES=

# Intervalo, em segundos, para verificar se as garagens remotas estão online.
IMAGE_DASHBOARD_REMOTE_HEALTH_INTERVAL_SECONDS=120

# Intervalo, em segundos, para sincronizar garagens remotas automaticamente.
# Esta sincronização é curta e usa apenas os últimos N dias.
IMAGE_DASHBOARD_REMOTE_SYNC_INTERVAL_SECONDS=180

# Quantidade de dias exportados/importados na sincronização curta.
IMAGE_DASHBOARD_REMOTE_SYNC_DAYS=30

# Intervalo, em segundos, para sincronizar o histórico completo.
IMAGE_DASHBOARD_REMOTE_FULL_SYNC_INTERVAL_SECONDS=3600

# Quantidade de dias da sincronização histórica.
# Use 0 para sincronizar todo o histórico.
IMAGE_DASHBOARD_REMOTE_FULL_SYNC_DAYS=0

# Timeout, em segundos, para chamadas HTTP às garagens remotas.
IMAGE_DASHBOARD_REMOTE_TIMEOUT_SECONDS=60

# Quantidade de arquivos enviada por página no export remoto.
# Reduza este valor se /api/export estiver dando timeout.
IMAGE_DASHBOARD_REMOTE_EXPORT_BATCH_SIZE=1000

# Tempo, em segundos, para manter respostas do dashboard em cache.
# Use 0 para desativar.
IMAGE_DASHBOARD_CACHE_SECONDS=20

# Ativa a coleta de duração dos vídeos com ffprobe.
# Requer ffprobe instalado no servidor. Use 0 para desativar.
IMAGE_DASHBOARD_ENABLE_DURATION=1

# Quantidade de arquivos gravados por lote durante a indexação.
# Aumentar pode acelerar, mas usa mais memória durante o processamento.
IMAGE_DASHBOARD_INDEX_BATCH_SIZE=5000

# Quantidade de câmeras gravadas por lote durante a indexação.
IMAGE_DASHBOARD_CAMERA_BATCH_SIZE=1000

# A cada quantos arquivos a indexação atualiza o progresso em memória.
IMAGE_DASHBOARD_SCAN_PROGRESS_EVERY_FILES=250

# Quantidade de durações gravadas por lote na fila de ffprobe.
IMAGE_DASHBOARD_DURATION_UPDATE_BATCH_SIZE=200

# Padrões de diretório/data e nome de arquivo aceitos na indexação.
# Altere apenas se o padrão real das pastas/arquivos mudar.
IMAGE_DASHBOARD_DATE_DIR_REGEX=^\d{4}-\d{2}-\d{2}$
IMAGE_DASHBOARD_TIMESTAMP_FILE_REGEX=^\d{14}(?:\..+)?$

# Extensões consideradas vídeo para coleta de duração.
IMAGE_DASHBOARD_VIDEO_EXTENSIONS=.mp4,.avi,.mkv,.mov,.wmv,.flv,.webm,.mpeg,.mpg,.m4v

# Níveis de cor da matriz no formato minimo:nivel separados por vírgula.
IMAGE_DASHBOARD_DAY_LEVELS=0:none,1:low,401:medium,801:high

# Veículo entra em alerta após esta quantidade de dias sem imagem.
IMAGE_DASHBOARD_ALERT_DAYS_WITHOUT_FILES=3

# Quantidade de linhas exibidas no ranking/resumo superior.
IMAGE_DASHBOARD_TOP_ROWS_LIMIT=8

# Habilita o botao de exportacao XLSX no relatorio.
IMAGE_DASHBOARD_EXPORT_XLSX_ENABLED=0

# Ajustes do SQLite.
# WAL melhora leitura e escrita simultâneas para este uso.
IMAGE_DASHBOARD_SQLITE_TIMEOUT_SECONDS=30
IMAGE_DASHBOARD_SQLITE_JOURNAL_MODE=WAL
IMAGE_DASHBOARD_SQLITE_SYNCHRONOUS=NORMAL
IMAGE_DASHBOARD_SQLITE_TEMP_STORE=MEMORY
IMAGE_DASHBOARD_SQLITE_CACHE_SIZE=-64000
IMAGE_DASHBOARD_SQLITE_BUSY_TIMEOUT_MS=30000

# Timeout usado especificamente pelo endpoint /api/db-status.
IMAGE_DASHBOARD_DB_STATUS_TIMEOUT_SECONDS=1

# Binário e timeout do ffprobe.
IMAGE_DASHBOARD_FFPROBE_BINARY=ffprobe
IMAGE_DASHBOARD_FFPROBE_TIMEOUT_SECONDS=1
